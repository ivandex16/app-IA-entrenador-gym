# ── Server ──
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/appgym
JWT_SECRET=change_me_super_secret_key_123
JWT_EXPIRES_IN=7d

# ── Optional: YouTube Data API (exercise videos) ──
YOUTUBE_API_KEY=

# ── Optional: OpenAI (advanced AI recommendations) ──
OPENAI_API_KEY=

# ── Optional: Google Gemini AI (routine generation) ──
GEMINI_API_KEY=

# ── Client (Vite prefix: VITE_) ──
VITE_API_URL=http://localhost:5000/api
